POSTGRES_USER="garaj"
POSTGRES_PASSWORD="replace-with-a-strong-password"
POSTGRES_DB="garaj"
DATABASE_URL="postgresql://garaj:replace-with-a-strong-password@localhost:5432/garaj?schema=public"
NEXTAUTH_URL="http://localhost:5001"
NEXTAUTH_SECRET="replace-with-a-random-secret"
UPLOAD_DIR="./uploads"

# Optional: only needed when running `npm run prisma:seed`.
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="replace-with-a-temporary-password"
